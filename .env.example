# ╔══════════════════════════════════════════════════════════════╗
# ║          MotoForge AI — Environment Configuration           ║
# ║    Copy this file to .env and fill in your API keys         ║
# ╚══════════════════════════════════════════════════════════════╝
#
# SETUP GUIDE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in every value marked [REQUIRED]
#   3. Optional values can be left empty or at their defaults
#   4. Never commit your .env file — it is already in .gitignore
#
# ── KEY: [REQUIRED] Must be set for core features to work
#         [OPTIONAL] Falls back to demo/local mode if not set
#         [DEV ONLY] Only needed for local development
# ═══════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────
# 1. 3D AI MODEL — TRELLIS via Replicate (PRIMARY)
# ─────────────────────────────────────────────────
# Used for: Image → 3D GLB model generation (TRELLIS model)
# Status:   [REQUIRED] for real AI generation
#           Without this, the app falls back to demo/procedural mode
#
# Setup:
#   1. Sign up at https://replicate.com
#   2. Go to https://replicate.com/account/api-tokens
#   3. Click "Create token" → copy the r8_*** token
#
REPLICATE_API_TOKEN=r8_your_replicate_api_token_here


# ─────────────────────────────────────────────────
# 2. FAL.AI — Alternative 3D AI Provider (FALLBACK)
# ─────────────────────────────────────────────────
# Used for: Fal.ai TripoSR as a fallback if Replicate is unavailable
# Status:   [OPTIONAL] — falls through to Replicate if empty
#
# Setup:
#   1. Sign up at https://fal.ai
#   2. Go to https://fal.ai/dashboard/keys
#   3. Click "Add key" → copy the key (format: uuid:secret)
#
FAL_KEY=your-fal-key-uuid:your-fal-key-secret


# ─────────────────────────────────────────────────
# 3. TRIPO3D — Legacy 3D AI Provider (DEPRECATED)
# ─────────────────────────────────────────────────
# Used for: Tripo3D image-to-model (superseded by TRELLIS)
# Status:   [OPTIONAL] — kept for backward compatibility
#
# Setup:
#   1. Sign up at https://www.tripo3d.ai
#   2. Go to https://platform.tripo3d.ai/api-keys
#   3. Create a key → copy the tsk_*** token
#
TRIPO_API_KEY=tsk_your_tripo3d_api_key_here


# ─────────────────────────────────────────────────
# 4. SUPABASE STORAGE — Cloud File Storage
# ─────────────────────────────────────────────────
# Used for: Storing uploaded bike images and generated .glb models
# Status:   [REQUIRED] for cloud storage
#           Without this, files are stored locally in /backend/storage/
#
# Setup:
#   1. Create a free project at https://supabase.com/dashboard
#   2. Go to Project Settings → API
#   3. Copy "Project URL"  → SUPABASE_URL
#   4. Copy "anon/public key" → SUPABASE_KEY
#   5. In Supabase → Storage, create two PUBLIC buckets:
#        • motoforge-images  (for uploaded/processed photos)
#        • motoforge-models  (for generated .glb 3D models)
#
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-public-key


# ─────────────────────────────────────────────────
# 5. MONGODB — Database (User Sessions & Builds)
# ─────────────────────────────────────────────────
# Used for: Storing upload sessions and bike build configurations
# Status:   [REQUIRED] for persistence
#           Defaults to local MongoDB if not set
#
# Option A — MongoDB Atlas (Cloud, Recommended):
#   1. Create free cluster at https://cloud.mongodb.com
#   2. Go to Database → Connect → Drivers
#   3. Copy the connection string (replace <password> with your db password)
#   Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/motoforge
#
# Option B — Local MongoDB:
#   Install MongoDB Community: https://www.mongodb.com/try/download/community
#   Use the default local URI below
#
MONGODB_URI=mongodb://localhost:27017


# ─────────────────────────────────────────────────
# 6. FIREBASE — Optional Alternative Database
# ─────────────────────────────────────────────────
# Used for: Alternative to MongoDB (Firestore real-time database)
# Status:   [OPTIONAL] — MongoDB is used if Firebase vars are empty
#
# Setup (only if you prefer Firebase over MongoDB):
#   1. Create a project at https://console.firebase.google.com
#   2. Go to Project Settings → Service Accounts
#   3. Click "Generate new private key" → download JSON
#   4. Copy values from the JSON into the variables below
#   NOTE: For FIREBASE_PRIVATE_KEY, keep the quotes and replace \n with actual newlines
#
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com


# ─────────────────────────────────────────────────
# 7. LOCAL STORAGE — Backend File Storage Path
# ─────────────────────────────────────────────────
# Used for: Local temporary storage of uploads/models before cloud upload
# Status:   [OPTIONAL] — defaults to "storage" folder inside /backend/
#
STORAGE_DIR=storage


# ─────────────────────────────────────────────────
# 8. FRONTEND — Vite Environment Variables
# ─────────────────────────────────────────────────
# Used for: Connecting the React frontend to the FastAPI backend
# Status:   [DEV ONLY] — change these when deploying to production
#
# For local development, leave as-is.
# For production, set VITE_API_URL to your deployed backend URL:
#   e.g. https://motoforge-api.onrender.com/api
#
VITE_API_URL=http://localhost:8000/api
VITE_BACKEND_URL=http://localhost:8000
